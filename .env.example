# VibeTree Configuration
# All settings are optional - defaults work for local development

# Server host (default: 127.0.0.1)
# WARNING: Do NOT change to 0.0.0.0 - VibeTree is a local-only tool
VIBETREE_HOST=127.0.0.1

# Server port (default: 3767)
VIBETREE_PORT=3767

# Database path (default: ~/.vibetree/vibetree.sqlite)
VIBETREE_DB=~/.vibetree/vibetree.sqlite

# Frontend API base URL (for development, default: http://127.0.0.1:3767)
VITE_API_BASE=http://127.0.0.1:3767
