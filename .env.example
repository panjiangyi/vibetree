# VibeTree Configuration
# All settings are optional - defaults work for local development

# Server host (default: 127.0.0.1)
# WARNING: Do NOT change to 0.0.0.0 - VibeTree is a local-only tool
VIBETREE_HOST=127.0.0.1

# Server port (default: 3767)
VIBETREE_PORT=3767

# Database path (default: ~/.vibetree/vibetree.sqlite)
VIBETREE_DB=~/.vibetree/vibetree.sqlite

# Single-user login credentials (required)
VIBETREE_AUTH_USERNAME=admin
VIBETREE_AUTH_PASSWORD=change-this-password

# Optional: auth/session tuning
# VIBETREE_AUTH_SESSION_TTL_MS=43200000
# VIBETREE_AUTH_IP_FAILURE_LIMIT=5
# VIBETREE_AUTH_IP_WINDOW_MS=900000
# VIBETREE_AUTH_GLOBAL_FAILURE_LIMIT=10
# VIBETREE_AUTH_GLOBAL_COOLDOWN_MS=900000

# Optional: set VITE_API_BASE only if you intentionally need a fixed same-origin-compatible base.
# In normal development, leave this unset so the Vite proxy can handle /api and /ws.
# VITE_API_BASE=
