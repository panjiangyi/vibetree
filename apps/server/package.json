{
  "name": "@vibetree/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cd src && find . -name '*.sql' -exec cp --parents {} ../dist/ ';'",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.0.2",
    "@vibetree/shared": "workspace:*",
    "better-sqlite3": "^11.9.1",
    "dotenv": "^17.4.2",
    "execa": "^9.5.2",
    "fastify": "^5.3.3",
    "nanoid": "^5.1.5",
    "node-pty": "^1.0.0",
    "ws": "^8.18.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
